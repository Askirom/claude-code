[Unit]
Description=ntfy push notifications
After=network-online.target

[Container]
Image=docker.io/binwiederhier/ntfy:latest
Exec=serve
PublishPort=127.0.0.1:2586:2586
Volume=%h/.config/ntfy/server.yml:/etc/ntfy/server.yml:ro,Z
Volume=ntfy-data:/var/lib/ntfy:Z

[Service]
Restart=always

[Install]
WantedBy=default.target
